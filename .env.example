# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres 
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the 
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Database Configuration
# For development with Docker: postgresql://trustrent_user:trustrent_password@localhost:5432/trustrent_dev?schema=public
# For production with Docker: postgresql://trustrent_user:trustrent_password@postgres:5432/trustrent?schema=public
DATABASE_URL="postgresql://trustrent_user:trustrent_password@localhost:5432/trustrent_dev?schema=public"
DATABASE_HOST=localhost

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# NextAuth.js Configuration
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Application Configuration
NODE_ENV=development
PORT=3000

# App Environment
NODE_ENV=development
